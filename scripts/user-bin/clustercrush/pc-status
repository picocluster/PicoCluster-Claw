#!/bin/bash
# pc-status — Show clustercrush / Ollama status
set -euo pipefail

echo "=== PicoCrush Status ==="
echo ""
echo "Ollama service: $(systemctl is-active ollama 2>/dev/null || echo 'n/a')"
echo ""
echo "Health check:"
if curl -sf --max-time 3 http://127.0.0.1:11434/api/tags >/dev/null 2>&1; then
  echo "  Ollama API: OK"
else
  echo "  Ollama API: FAIL"
fi
echo ""
echo "Memory (unified with GPU on Jetson):"
free -h | awk '/^Mem:/ {printf "  %s used / %s total\n", $3, $2}'
if [[ -r /sys/devices/gpu.0/load ]]; then
  GPU_LOAD=$(cat /sys/devices/gpu.0/load 2>/dev/null)
  # Value is in 0.1% units (0-1000)
  echo "  GPU load: $((GPU_LOAD / 10))%"
fi
echo ""
echo "Active models (loaded in GPU):"
curl -sf http://127.0.0.1:11434/api/ps 2>/dev/null | python3 -c "
import sys, json
data = json.load(sys.stdin)
models = data.get('models', [])
if not models:
    print('  (none loaded)')
else:
    for m in models:
        vram_gb = m.get('size_vram', 0) / (1024**3)
        print(f'  {m[\"name\"]}: {vram_gb:.1f}GB VRAM')
" 2>/dev/null || echo "  n/a"
echo ""
echo "Installed models:"
ollama list 2>/dev/null | tail -n +2 | awk '{printf "  %s (%s)\n", $1, $3$4}' || echo "  n/a"
echo ""
# Show /mnt/nvme if it's a separate mountpoint, otherwise /
if mountpoint -q /mnt/nvme 2>/dev/null; then
  DISK_PATH="/mnt/nvme"
else
  DISK_PATH="/"
fi
echo "Disk ($DISK_PATH): $(df -h "$DISK_PATH" | awk 'NR==2 {printf "%s used / %s total (%s used)", $3, $2, $5}')"
echo "Load: $(cat /proc/loadavg | awk '{print $1, $2, $3}')"
