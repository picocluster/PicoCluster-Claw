#!/bin/bash
# pc-update-models — Update Ollama models on clustercrush
# Usage: pc-update-models           # Pull all default models
#        pc-update-models pull llama3.2:3b  # Pull a specific model
set -euo pipefail

CRUSH_HOST="${CRUSH_HOST:-picocluster@10.1.10.221}"

echo "Running model update on clustercrush..."
ssh -o ConnectTimeout=5 "$CRUSH_HOST" "sudo bash /opt/clusterclaw/scripts/setup/update-clustercrush.sh $*"
