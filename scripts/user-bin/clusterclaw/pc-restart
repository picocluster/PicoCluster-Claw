#!/bin/bash
# pc-restart — Restart the PicoCluster Claw cluster (or one node)
# Usage: pc-restart           # Restart both nodes
#        pc-restart clusterclaw  # Restart clusterclaw only
#        pc-restart clustercrush # Restart clustercrush only
set -euo pipefail

TARGET="${1:-all}"
TOKEN="${SHUTDOWN_TOKEN:-picocluster-shutdown}"

case "$TARGET" in
  all|clusterclaw|clustercrush) ;;
  *)
    echo "Usage: pc-restart [all|clusterclaw|clustercrush]"
    exit 1
    ;;
esac

read -rp "Restart ${TARGET}? [y/N] " yn
[[ "$yn" =~ ^[Yy]$ ]] || { echo "Cancelled."; exit 0; }

curl -sf -X POST http://127.0.0.1:8888/restart \
  -H "Content-Type: application/json" \
  -d "{\"token\":\"$TOKEN\",\"target\":\"$TARGET\"}"
echo ""
echo "Restart initiated for: $TARGET"
