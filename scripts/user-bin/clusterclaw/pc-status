#!/bin/bash
# pc-status — Show PicoCluster Claw service status
set -euo pipefail

echo "=== PicoCluster Claw Status ==="
echo ""
echo "Docker containers:"
sudo docker ps --format "  {{.Names}}: {{.Status}}" 2>/dev/null
echo ""
echo "Systemd services:"
for svc in clusterclaw-leds shutdown-api openclaw-led-bridge; do
  state=$(systemctl is-active "$svc" 2>/dev/null || true)
  echo "  $svc: ${state:-unknown}"
done
echo ""
echo "Health checks:"
check_http() {
  local name="$1" url="$2"
  if curl -sf --max-time 3 "$url" >/dev/null 2>&1; then
    echo "  $name: OK"
  else
    echo "  $name: FAIL"
  fi
}
check_tcp() {
  local name="$1" host="$2" port="$3"
  if timeout 2 bash -c "</dev/tcp/$host/$port" 2>/dev/null; then
    echo "  $name: OK"
  else
    echo "  $name: FAIL"
  fi
}
check_http "ThreadWeaver" "http://127.0.0.1:8000/api/settings"
check_http "OpenClaw    " "http://127.0.0.1:18789/"
check_tcp  "LED API     " "127.0.0.1" 7777
check_tcp  "Shutdown API" "127.0.0.1" 8888
check_http "Portal      " "http://127.0.0.1:80/"
check_http "Ollama      " "http://10.1.10.221:11434/api/tags"
echo ""
echo "Disk: $(df -h / | awk 'NR==2 {printf "%s used / %s total (%s used)", $3, $2, $5}')"
echo "Load: $(cat /proc/loadavg | awk '{print $1, $2, $3}')"
