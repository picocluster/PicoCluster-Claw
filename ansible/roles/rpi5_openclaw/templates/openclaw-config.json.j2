{
  "gateway": {
    "mode": "local",
    "auth": {
      "token": "{{ openclaw_auth_token | default('picocluster-token') }}"
    },
    "bind": "0.0.0.0"
  },
  "models": {
    "providers": {
      "local": {
        "baseUrl": "{{ llama_endpoint }}",
        "apiKey": "none",
        "models": [
          {
            "id": "{{ llama_default_model }}",
            "name": "Llama 3.2 3B"
          }
        ]
      }
    }
  }
}
