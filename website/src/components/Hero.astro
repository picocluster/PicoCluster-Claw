---
/**
 * Landing-page hero. Three beats:
 *
 *   1. Name the human pain (context anxiety — keeps the v1 emotional bridge)
 *   2. Name the architectural cause (model-centric AI / context debt / reasoning tax)
 *   3. State what CTXone gives back: external context, structured execution,
 *      control over tokens and model choice
 */
import InstallOneliner from './InstallOneliner.astro';
---

<section class="hero">
	<div class="scanlines" aria-hidden="true"></div>
	<div class="container">
		<div class="eyebrow">
			<span class="dot"></span>
			<span class="eyebrow-text">CTXONE // system-centric AI</span>
		</div>

		<h1>
			Stop paying a reasoning tax
			<span class="glow">for context you already have.</span>
		</h1>

		<p class="lede">
			Every session you start from scratch, the model burns tokens
			reconstructing what it should already know. That's not
			intelligence — that's
			<strong class="anxiety">context compensation</strong>.
			Your model isn't thinking. It's catching up.
		</p>

		<p class="lede">
			CTXone is the external context layer that ends it.
			Persistent memory, structured plans, and full provenance —
			so the model
			<strong class="pillar pillar-stateful">executes</strong>
			within context instead of
			<strong class="pillar pillar-burn">reasoning</strong>
			its way back to it. Smaller models work better.
			Token costs drop. You stay in control.
		</p>

		<InstallOneliner />

		<div class="cta-row">
			<a class="btn btn-primary" href="/getting-started/quickstart/">
				Get started →
			</a>
			<a
				class="btn btn-secondary"
				href="https://github.com/ctxone/ctxone"
				rel="noopener"
			>
				View on GitHub
			</a>
		</div>

		<p class="badges">
			<span class="badge">System-Centric</span>
			<span class="badge">Model-Agnostic</span>
			<span class="badge">Self-hosted</span>
			<span class="badge">Zero telemetry</span>
			<span class="badge">BSL-1.1 → Apache 2.0</span>
		</p>
	</div>
</section>

<style>
	.hero {
		position: relative;
		padding: 6rem 0 4.5rem 0;
		background:
			radial-gradient(
				ellipse 60% 80% at 50% 0%,
				rgba(34, 197, 94, 0.12),
				transparent 60%
			),
			radial-gradient(
				ellipse 80% 60% at 30% 20%,
				rgba(59, 130, 246, 0.18),
				transparent 55%
			),
			radial-gradient(
				ellipse 60% 60% at 80% 10%,
				rgba(252, 211, 77, 0.06),
				transparent 55%
			),
			var(--ctx-bg);
		border-bottom: 1px solid var(--ctx-border-lo);
		overflow: hidden;
	}

	/* CRT scanline texture — repeating horizontal stripes at very
	 * low opacity. Gives the hero a subtle terminal-phosphor feel
	 * without being a retro gimmick. */
	.scanlines {
		position: absolute;
		inset: 0;
		pointer-events: none;
		background: repeating-linear-gradient(
			to bottom,
			transparent 0,
			transparent 2px,
			rgba(255, 255, 255, 0.018) 2px,
			rgba(255, 255, 255, 0.018) 3px
		);
		mix-blend-mode: screen;
	}

	.container {
		position: relative;
		z-index: 1;
	}

	.eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		padding: 0.35rem 0.85rem;
		background: rgba(34, 197, 94, 0.08);
		border: 1px solid rgba(34, 197, 94, 0.28);
		border-radius: 999px;
		font-family: var(--ctx-font-mono);
		font-size: 0.7rem;
		letter-spacing: 0.12em;
		color: var(--ctx-success);
		margin-bottom: 1.75rem;
	}

	.eyebrow .dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--ctx-success);
		box-shadow: 0 0 10px rgba(34, 197, 94, 0.8);
		animation: pulse 2s ease-in-out infinite;
	}

	@keyframes pulse {
		0%, 100% {
			opacity: 1;
		}
		50% {
			opacity: 0.4;
		}
	}

	.eyebrow-text {
		font-weight: 700;
	}

	h1 {
		font-size: clamp(2.25rem, 5.5vw, 3.75rem);
		font-weight: 800;
		line-height: 1.05;
		margin: 0 0 1.5rem 0;
		color: #ffffff;
		letter-spacing: -0.025em;
		max-width: 20ch;
	}

	h1 .glow {
		color: var(--ctx-success);
		text-shadow:
			0 0 30px rgba(34, 197, 94, 0.4),
			0 0 60px rgba(34, 197, 94, 0.2);
	}

	.lede {
		font-size: 1.1rem;
		color: var(--ctx-text-dim);
		margin: 0 0 1.1rem 0;
		max-width: 38rem;
		line-height: 1.65;
	}

	.lede:last-of-type {
		margin-bottom: 2.25rem;
	}

	.anxiety {
		color: var(--ctx-warn);
		font-weight: 600;
		text-shadow: 0 0 16px rgba(252, 211, 77, 0.25);
	}

	.pillar {
		font-weight: 600;
	}

	.pillar-stateful {
		color: var(--ctx-accent);
	}

	.pillar-burn {
		color: var(--ctx-error, #ef4444);
	}

	.cta-row {
		display: flex;
		gap: 0.75rem;
		margin: 1.75rem 0 2.5rem 0;
		flex-wrap: wrap;
	}

	.badges {
		display: flex;
		gap: 0.6rem;
		flex-wrap: wrap;
		margin: 0;
	}

	.badge {
		display: inline-flex;
		align-items: center;
		padding: 0.35rem 0.75rem;
		background: rgba(17, 17, 17, 0.6);
		border: 1px solid var(--ctx-border);
		border-radius: 999px;
		font-size: 0.72rem;
		color: var(--ctx-text-dim);
		font-family: var(--ctx-font-mono);
		letter-spacing: 0.04em;
	}

	@media (max-width: 640px) {
		.hero {
			padding: 4rem 0 3rem 0;
		}
	}
</style>
