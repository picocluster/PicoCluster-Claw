---
/**
 * Logo-strip-ish section showing everything CTXone integrates with.
 * Pure text (no external logo assets to juggle licensing for) —
 * each "tile" is a card with the tool name, the integration method,
 * and a link to the relevant doc.
 */

type Tool = {
	name: string;
	kind: string;
	href: string;
};

const coding: Tool[] = [
	{ name: 'Claude Code', kind: 'MCP', href: '/integrations/ai-coding-tools/' },
	{ name: 'Cursor', kind: 'MCP', href: '/integrations/ai-coding-tools/' },
	{ name: 'VS Code', kind: 'MCP', href: '/integrations/ai-coding-tools/' },
	{ name: 'Codex', kind: 'MCP', href: '/integrations/ai-coding-tools/' },
	{ name: 'Gemini', kind: 'MCP', href: '/integrations/ai-coding-tools/' },
];

const chat: Tool[] = [
	{
		name: 'Open WebUI',
		kind: 'Tool + Filter',
		href: '/integrations/open-webui/',
	},
	{
		name: 'ThreadWeaver',
		kind: 'MCP + ASG + filter',
		href: '/integrations/ai-coding-tools/',
	},
];

const direct: Tool[] = [
	{ name: 'Python', kind: 'pip install ctxone', href: 'https://pypi.org/project/ctxone/' },
	{ name: 'CLI', kind: 'ctx …', href: '/reference/cli/' },
	{ name: 'HTTP API', kind: 'REST', href: '/reference/http-api/' },
];

// Lens is the full browser UI: plans dashboard, session history,
// memory browser, branch/taint/diff, ⌘K palette, 15s auto-refresh.
const ui: Tool[] = [
	{ name: 'Lens Dashboard', kind: 'Plans · Memory · Branches · Taint', href: '/how-it-works/architecture/' },
];
---

<section class="section">
	<div class="container">
		<h2 class="section-title">Works with the tools you already use</h2>
		<p class="section-lede">
			CTXone exposes MCP for AI coding tools, native plugins for
			chat UIs, and direct client libraries for everything else.
			<code>ctx init</code> auto-detects and wires them in one command.
		</p>

		<div class="group">
			<h3>AI coding tools</h3>
			<div class="tiles">
				{
					coding.map((t) => (
						<a class="tile" href={t.href}>
							<span class="tile-name">{t.name}</span>
							<span class="tile-kind">{t.kind}</span>
						</a>
					))
				}
			</div>
		</div>

		<div class="group">
			<h3>Self-hosted chat</h3>
			<div class="tiles">
				{
					chat.map((t) => (
						<a class="tile" href={t.href}>
							<span class="tile-name">{t.name}</span>
							<span class="tile-kind">{t.kind}</span>
						</a>
					))
				}
			</div>
		</div>

		<div class="group">
			<h3>Direct embed</h3>
			<div class="tiles">
				{
					direct.map((t) => (
						<a class="tile" href={t.href}>
							<span class="tile-name">{t.name}</span>
							<span class="tile-kind">{t.kind}</span>
						</a>
					))
				}
			</div>
		</div>

		<div class="group">
			<h3>Inspect &amp; browse</h3>
			<div class="tiles">
				{
					ui.map((t) => (
						<a class="tile tile-lens" href={t.href}>
							<span class="tile-name">{t.name}</span>
							<span class="tile-kind">{t.kind}</span>
						</a>
					))
				}
			</div>
		</div>

		<p class="model-agnostic">
			<span class="ma-badge">Model-Agnostic</span>
			Works with any model behind any tool — Claude, GPT, Gemini, local
			models via Ollama. CTXone doesn't depend on the model's memory.
			The system holds the context.
		</p>
	</div>
</section>

<style>
	.group {
		margin-top: 1.75rem;
	}

	.group h3 {
		font-size: 0.75rem;
		color: var(--ctx-text-faint);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin: 0 0 0.75rem 0;
		font-weight: 600;
	}

	.tiles {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	.tile {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		padding: 0.75rem 1.1rem;
		background: var(--ctx-panel);
		border: 1px solid var(--ctx-border);
		border-radius: var(--ctx-radius-md);
		text-decoration: none;
		transition: all 0.15s;
		min-width: 10rem;
	}

	.tile:hover {
		background: var(--ctx-panel-hi);
		border-color: var(--ctx-accent-dim);
		text-decoration: none;
	}

	.tile-name {
		color: #ffffff;
		font-weight: 600;
		font-size: 0.95rem;
	}

	.tile-kind {
		color: var(--ctx-text-faint);
		font-size: 0.75rem;
		font-family: var(--ctx-font-mono);
	}

	.section-lede code {
		background: var(--ctx-panel);
		border: 1px solid var(--ctx-border);
		padding: 0.1rem 0.4rem;
		border-radius: var(--ctx-radius-sm);
		font-size: 0.9em;
		color: var(--ctx-accent-text);
		font-family: var(--ctx-font-mono);
	}

	.tile-lens {
		border-color: rgba(34, 197, 94, 0.25);
	}

	.tile-lens .tile-name {
		color: var(--ctx-success);
	}

	.model-agnostic {
		margin-top: 2rem;
		padding: 1rem 1.25rem;
		background: var(--ctx-panel);
		border: 1px solid var(--ctx-border);
		border-left: 3px solid var(--ctx-accent);
		border-radius: 0 var(--ctx-radius-md) var(--ctx-radius-md) 0;
		font-size: 0.88rem;
		color: var(--ctx-text-dim);
		line-height: 1.6;
		display: flex;
		align-items: center;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.ma-badge {
		font-family: var(--ctx-font-mono);
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		color: var(--ctx-accent);
		background: rgba(59, 130, 246, 0.08);
		border: 1px solid rgba(59, 130, 246, 0.28);
		padding: 0.3rem 0.7rem;
		border-radius: 999px;
		white-space: nowrap;
	}
</style>
