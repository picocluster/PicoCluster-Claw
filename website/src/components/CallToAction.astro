<section class="section cta-section">
	<div class="container">
		<h2>Your AI. Your rules.<br />Your hardware.</h2>
		<p class="lede">
			PicoCluster Claw ships ready to run — OpenClaw agents, local LLM inference,
			ThreadWeaver chat, 28 MCP tools. Plug in, power on, private AI in minutes.
			No subscription. No cloud dependency. Under $2/month to keep running.
		</p>
		<div class="links">
			<a class="btn btn-primary" href="https://picocluster.com" rel="noopener">
				Order from PicoCluster →
			</a>
			<a class="btn btn-secondary" href="/docs/quickstart/">
				Read the docs
			</a>
		</div>
		<p class="software-note">
			Not ready for hardware? Install on
			<a href="/docs/quickstart/">Mac, Linux, or Windows</a> — same stack, your machine.
		</p>
	</div>
</section>

<style>
	.cta-section {
		padding: 5rem 0;
		background:
			radial-gradient(
				ellipse at bottom,
				rgba(27, 117, 186, 0.08),
				transparent 60%
			),
			var(--ctx-bg);
		text-align: center;
		border-bottom: none;
	}

	.cta-section .container {
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	h2 {
		font-size: clamp(1.75rem, 3.5vw, 2.5rem);
		font-weight: 800;
		color: #ffffff;
		margin: 0 0 0.85rem 0;
		letter-spacing: -0.02em;
		line-height: 1.1;
	}

	.lede {
		color: var(--ctx-text-dim);
		font-size: 1rem;
		max-width: 40rem;
		margin: 0 0 2rem 0;
		line-height: 1.65;
	}

	.links {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
		justify-content: center;
	}

	.software-note {
		margin-top: 1.75rem;
		color: var(--ctx-text-faint);
		font-size: 0.85rem;
	}
</style>
