---
const year = new Date().getFullYear();
---

<footer class="footer">
	<div class="container footer-grid">
		<div class="col-brand">
			<div class="wordmark">PicoCluster Claw</div>
			<p class="tag">Private AI on your desk.</p>
		</div>

		<div class="col-links">
			<h4>Docs</h4>
			<ul>
				<li><a href="/docs/quickstart/">Quickstart</a></li>
				<li><a href="/docs/architecture/">Architecture</a></li>
				<li><a href="/docs/mcp-tools/">MCP tools</a></li>
				<li><a href="/docs/troubleshooting/">Troubleshooting</a></li>
			</ul>
		</div>

		<div class="col-links">
			<h4>Platforms</h4>
			<ul>
				<li><a href="/#platforms">Hardware appliance</a></li>
				<li><a href="/docs/quickstart/">macOS</a></li>
				<li><a href="/docs/quickstart/">Linux</a></li>
				<li><a href="/docs/quickstart/">Windows</a></li>
			</ul>
		</div>

		<div class="col-links">
			<h4>Project</h4>
			<ul>
				<li>
					<a href="https://picocluster.com" rel="noopener">PicoCluster store</a>
				</li>
				<li>
					<a href="https://github.com/picocluster/picocluster-claw" rel="noopener">GitHub</a>
				</li>
				<li>
					<a href="https://github.com/picocluster/picocluster-claw/releases" rel="noopener">Releases</a>
				</li>
				<li>
					<a href="https://github.com/picocluster/picocluster-claw/issues" rel="noopener">Report an issue</a>
				</li>
			</ul>
		</div>
	</div>

	<div class="container footer-base">
		<div class="copyright">
			© {year} PicoCluster. Open source — see LICENSE.
		</div>
		<div class="built-on">
			Built on
			<a href="https://github.com/picocluster/asg" rel="noopener">AgentStateGraph</a>
		</div>
	</div>
</footer>

<style>
	.footer {
		background: #050505;
		border-top: 1px solid var(--ctx-border);
		padding: 3rem 0 1.5rem 0;
		color: var(--ctx-text-dim);
		font-size: 0.85rem;
	}

	.footer-grid {
		display: grid;
		grid-template-columns: 1.4fr 1fr 1fr 1fr;
		gap: 2rem;
		padding-bottom: 2rem;
		border-bottom: 1px solid var(--ctx-border-lo);
	}

	.col-brand .wordmark {
		color: var(--claw-blue-text);
		font-family: var(--ctx-font-mono);
		font-weight: 800;
		font-size: 1.05rem;
		margin-bottom: 0.35rem;
	}

	.col-brand .tag {
		color: var(--ctx-text-dim);
		margin: 0;
		max-width: 18rem;
	}

	.col-links h4 {
		color: #ffffff;
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin: 0 0 0.75rem 0;
		font-weight: 600;
	}

	.col-links ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.col-links li {
		margin-bottom: 0.4rem;
	}

	.col-links a {
		color: var(--ctx-text-dim);
	}

	.col-links a:hover {
		color: var(--ctx-text);
		text-decoration: none;
	}

	.footer-base {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-top: 1.5rem;
		font-size: 0.75rem;
		color: var(--ctx-text-faint);
		flex-wrap: wrap;
		gap: 1rem;
	}

	.footer-base a {
		color: var(--ctx-text-dim);
	}

	@media (max-width: 820px) {
		.footer-grid {
			grid-template-columns: 1fr 1fr;
		}
	}

	@media (max-width: 520px) {
		.footer-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
