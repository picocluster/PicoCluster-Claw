[Unit]
Description=OpenClaw LED Bridge
After=picocluster-claw-leds.service openclaw.service
Wants=picocluster-claw-leds.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 /opt/picocluster-claw/leds/openclaw_led_bridge.py
Restart=always
RestartSec=10
User=root

[Install]
WantedBy=multi-user.target
